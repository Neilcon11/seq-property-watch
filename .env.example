NODE_ENV=production
PORT=3000

# Required for persistent records and de-duplicated alerts.
DATABASE_URL=

# Turn on scheduled polling after Gmail + Telegram variables are ready.
AUTO_CHECK_ENABLED=false
CHECK_INTERVAL_MINUTES=30
CHECK_SECRET=

# Gmail API OAuth credentials for the deployed Railway app.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_QUERY=newer_than:2d (land OR "home and land" OR townhouse OR "house and land" OR "land release") ("Sunshine Coast" OR Brisbane OR "Moreton Bay" OR Queensland OR SEQ)

# Comma-separated public land listing pages to monitor.
ONLINE_LAND_SOURCE_URLS=https://www.stockland.com.au/residential/qld/aura/land-for-sale,https://www.stockland.com.au/residential/qld/aura,https://harmony.avid.com.au/land-for-sale/,https://www.realestate.com.au/buy/property-residential+land-in-sunshine+coast,+qld/list-1,https://www.domain.com.au/sale/sunshine-coast-qld/land/

# Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Investment assumptions. Change these in Railway Variables to tune estimates.
INTEREST_RATE=0.065
DEPOSIT_RATE=0.20
EXPENSE_RATE=0.25
CAPITAL_GROWTH_RATE=0.05
WEEKLY_RENT_TOWNHOUSE=650
WEEKLY_RENT_HOUSE=760
WEEKLY_RENT_ROOM=220
WEEKLY_RENT_GRANNY_FLAT=400
NODE_ENV=production
# Railway injects PORT automatically. Set locally only if needed.
# PORT=3000

# No database is required for the current static/email-sourced dashboard.
# Add DATABASE_URL later only if persistent storage is introduced.
# DATABASE_URL=
