NODE_ENV=production
PORT=3000
DATABASE_URL=

# Gmail sync. The app auto-runs every 5 minutes when these are present unless AUTO_CHECK_ENABLED=false.
AUTO_CHECK_ENABLED=true
CHECK_INTERVAL_MINUTES=5
CHECK_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_QUERY=newer_than:120d -in:spam -in:trash ("price list" OR "land update" OR "stock list" OR "new release" OR package OR "house and land" OR "home and land" OR lot OR stage OR estate OR terrace OR townhome OR townhouse OR registration OR floorplan OR facade OR "site plan" OR available OR released OR "fixed price")
GMAIL_BACKFILL_QUERY=

# Public land listing pages to monitor.
ONLINE_LAND_SOURCE_URLS=https://www.stockland.com.au/residential/qld/aura/land-for-sale,https://www.stockland.com.au/residential/qld/aura,https://harmony.avid.com.au/land-for-sale/,https://www.realestate.com.au/buy/property-residential+land-in-sunshine+coast,+qld/list-1,https://www.domain.com.au/sale/sunshine-coast-qld/land/

# Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Persistent media / object storage. Configure an S3-compatible bucket for production media files.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MEDIA_BASE_URL=

# Investment assumptions.
INTEREST_RATE=0.065
DEPOSIT_RATE=0.20
EXPENSE_RATE=0.25
CAPITAL_GROWTH_RATE=0.05
WEEKLY_RENT_TOWNHOUSE=650
WEEKLY_RENT_HOUSE=760
WEEKLY_RENT_ROOM=220
WEEKLY_RENT_GRANNY_FLAT=400
